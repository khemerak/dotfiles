# CURSOR_ANIMATION
cursor_trail 2
cursor_trail_decay 0.1 0.4
cursor_trail_start_threshold 2


# KITTY_FONTS
font_family      	family="Fira Code"
bold_font        	auto
italic_font      	auto
bold_italic_font 	auto
font_size        	12

scrollback_lines 	5000
scrollback_pager_history_size 10

tab_bar_style 		round

shell 			/bin/fish


