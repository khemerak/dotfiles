// -*- mode: jsonc -*-
{
    "layer": "top", 
    "position": "top", 
    "margin-top": 8,
    "margin-left": 5,
    "margin-right": 5,
    "spacing": 4, 
    
    // Choose the order of the modules
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window" 
    ],

    "modules-center": [
        "clock",
        "group/media"
    ],

    "modules-right": [
        "group/hardware",
        "group/audio",
        "group/power",
        "tray",
        "custom/power"
    ],

    // --- RIGHT SIDE GROUPS (Fixes the gaps) ---
    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory", "temperature"]
    },

    "group/audio": {
        "orientation": "horizontal",
        "modules": ["backlight", "pulseaudio"]
    },

    "group/power": {
        "orientation": "horizontal",
        "modules": ["battery", "power-profiles-daemon"]
    },

    // --- LEFT MODULES ---
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "format": "{name} {icon}", 
        "format-icons": {
            "1": "п„  ", 
            "2": "п‰© ", 
            "3": "п„Ў ", 
            "4": "пЃ» ", 
            "urgent": "пЃЄ ",
            "active": "п‹ђ ",
            "default": "п‹ђ "
        },
        "sort-by-number": true
    },
    
    "hyprland/window": {
        "format": "п„µ  {}", 
        "max-length": 50
    },
    
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },

    // --- MEDIA PLAYER BLOCK ---
    "group/media": {
        "orientation": "vertical",
        "modules": [
            "group/controls", 
            "custom/mpris-scroll" 
        ]
    },

    "group/controls": {
        "orientation": "horizontal",
        "modules": [
            "custom/record",
            "custom/prev",
            "custom/playpause",
            "custom/next"
        ]
    },

    "custom/mpris-scroll": {
        "format": "{}",
        "return-type": "json",
        "exec": "~/.config/waybar/scroll_media.sh",
        "tail": true,
        "tooltip": false
    },

    "custom/record": {
        "format": "{}",
        "return-type": "json",
        "exec": "playerctl -a metadata --format '{\"text\": \"у°“‡\", \"class\": \"{{status}}\"}' -F",
        "tooltip": false
    },

    "custom/prev": {
        "format": " у°’® ",
        "on-click": "playerctl previous",
        "tooltip": false
    },

    "custom/playpause": {
        "format": " {icon} ",
        "return-type": "json",
        "exec": "playerctl -a metadata --format '{\"text\": \"{{status}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
        "on-click": "playerctl play-pause",
        "format-icons": {
            "Playing": "у°Џ¤",
            "Paused": "у°ђЉ"
        },
        "tooltip": false
    },

    "custom/next": {
        "format": " у°’­ ",
        "on-click": "playerctl next",
        "tooltip": false
    },

    // --- HARDWARE MODULES ---
    "cpu": {
        "format": "{usage}% п‹›",
        "tooltip": false
    },
    "memory": {
        "format": "{}% пѓ‰"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "{temperatureC}В°C {icon}",
        "format-icons": ["пќ«", "п‹‰", "пќ©"]
    },
    
    // --- AUDIO & BRIGHTNESS ---
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["у°ѓћ", "у°ѓџ", "у°ѓ "],
        "on-scroll-up": "swayosd-client --brightness raise",
        "on-scroll-down": "swayosd-client --brightness lower",
        "smooth-scrolling-threshold": 1
    },
    
    "pulseaudio": {
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}пЉ” {format_source}",
        "format-bluetooth-muted": "пљ© {icon}пЉ” {format_source}",
        "format-muted": "пљ© {format_source}",
        "format-source": "{volume}% п„°",
        "format-source-muted": "п„±",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "п–ђ",
            "headset": "п–ђ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click": "pavucontrol"
    },

    // --- POWER & TRAY ---
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{capacity}% п—§",
        "format-plugged": "{capacity}% п‡¦",
        "format-alt": "{time} {icon}",
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
    },

    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "пѓ§",
        "performance": "пѓ§",
        "balanced": "п‰Ћ",
        "power-saver": "пЃ¬"
      }
    },

    "tray": {
        "spacing": 10
    },

    "custom/power": {
        "format": "вЏ»", 
        "tooltip": false,
        "menu": "on-click",
        "on-click": "",
        "menu-file": "$HOME/.config/waybar/power_menu.xml",
        "menu-actions": {
            "lock": "hyperlock",
            "sleep": "systemctl suspend",    
            "reboot": "systemctl reboot",
            "shutdown": "systemctl poweroff"
        }
    }
}
